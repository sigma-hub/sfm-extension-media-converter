{
  "$schema": "./node_modules/@sigma-file-manager/api/manifest.schema.json",
  "id": "sigma.media-converter",
  "name": "Media Converter",
  "version": "1.1.0",
  "publisher": {
    "name": "sigma-hub",
    "url": "https://github.com/sigma-hub"
  },
  "repository": "https://github.com/sigma-hub/sfm-extension-media-converter",
  "license": "MIT",
  "categories": [
    "Media"
  ],
  "extensionType": "api",
  "type": "module",
  "main": "dist/index.js",
  "icon": "icon.png",
  "media": [
    {
      "title": "Preview",
      "src": "preview-1.jpg",
      "type": "image"
    },
    {
      "title": "GIF",
      "src": "preview-2.jpg",
      "type": "image"
    },
    {
      "title": "Commands",
      "src": "preview-3.jpg",
      "type": "image"
    }
  ],
  "permissions": [
    "contextMenu",
    "commands",
    "notifications",
    "fs.read",
    "fs.write",
    "shell"
  ],
  "activationEvents": [
    "onInstall",
    "onUninstall",
    "onStartup",
    "onUpdate",
    "onEnable",
    "onDisable",
    "onCommand:sigma.media-converter.convert",
    "onCommand:sigma.media-converter.reduceSize"
  ],
  "contributes": {
    "commands": [
      {
        "id": "convert",
        "title": "Convert Media",
        "description": "Convert videos and images to other formats using FFmpeg"
      },
      {
        "id": "reduceSize",
        "title": "Reduce Media Size",
        "description": "Re-encode media to shrink files with minimal visible quality loss",
        "icon": "ImageDown"
      }
    ],
    "contextMenu": [
      {
        "id": "convert",
        "title": "Convert",
        "icon": "RefreshCw",
        "group": "extensions",
        "order": 1,
        "when": {
          "entryType": "file",
          "fileExtensions": [
            "mp4",
            "mkv",
            "webm",
            "avi",
            "mov",
            "wmv",
            "flv",
            "ts",
            "mts",
            "m4v",
            "3gp",
            "png",
            "jpg",
            "jpeg",
            "webp",
            "bmp",
            "tiff",
            "tif",
            "avif",
            "gif"
          ]
        }
      },
      {
        "id": "reduceSize",
        "title": "Reduce size",
        "icon": "ImageDown",
        "group": "extensions",
        "order": 2,
        "when": {
          "entryType": "file",
          "fileExtensions": [
            "mp4",
            "mkv",
            "webm",
            "avi",
            "mov",
            "wmv",
            "flv",
            "ts",
            "mts",
            "m4v",
            "3gp",
            "png",
            "jpg",
            "jpeg",
            "webp",
            "bmp",
            "tiff",
            "tif",
            "avif",
            "gif"
          ]
        }
      }
    ]
  },
  "engines": {
    "sigmaFileManager": ">=2.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@sigma-file-manager/api": "^1.5.0",
    "typescript": "~5.8.0"
  },
  "platforms": [
    "windows",
    "macos",
    "linux"
  ],
  "binaries": [
    {
      "id": "ffmpeg",
      "name": "FFmpeg",
      "version": "8.1",
      "repository": "https://ffmpeg.org",
      "assets": [
        {
          "platform": "windows",
          "arch": [
            "x64"
          ],
          "downloadUrl": "https://github.com/BtbN/FFmpeg-Builds/releases/download/autobuild-2026-03-31-13-11/ffmpeg-n8.1-7-ga3475e2554-win64-gpl-8.1.zip",
          "integrity": "sha256:052df9b4d96bbe033456a87723d76f0efa14d1b77f01130ba3899332f0a10b9a",
          "archive": true,
          "executable": "bin/ffmpeg.exe"
        },
        {
          "platform": "windows",
