{
  "$schema": "https://raw.githubusercontent.com/aleksey-hoffman/sigma-file-manager/main/packages/api/manifest.schema.json",
  "id": "sigma.media-converter",
  "name": "Media Converter",
  "version": "1.0.11",
  "publisher": {
    "name": "sigma-hub",
    "url": "https://github.com/sigma-hub"
  },
  "repository": "https://github.com/sigma-hub/sfm-extension-media-converter",
  "license": "MIT",
  "categories": [
    "Media"
  ],
  "tags": [
    "video",
    "image",
    "convert",
    "ffmpeg",
    "gif",
    "compress",
    "optimize"
  ],
  "extensionType": "api",
  "main": "index.js",
  "icon": "icon.png",
  "permissions": [
    "contextMenu",
    "commands",
    "notifications",
    "fs.read",
    "fs.write",
    "shell"
  ],
  "activationEvents": [
    "onInstall",
    "onUninstall",
    "onStartup",
    "onUpdate",
    "onEnable",
    "onDisable",
    "onCommand:sigma.media-converter.convert",
    "onCommand:sigma.media-converter.reduceSize"
  ],
  "contributes": {
    "configuration": {
      "title": "Media Converter Settings",
      "properties": {
        "autoUpdateBinary": {
          "type": "boolean",
          "default": true,
          "description": "Automatically check for and download FFmpeg updates on app startup"
        }
      }
    },
    "commands": [
      {
        "id": "convert",
        "title": "Convert Media",
        "description": "Convert videos and images to other formats using FFmpeg"
      },
      {
        "id": "reduceSize",
        "title": "Reduce Media Size",
        "description": "Re-encode media to shrink files with minimal visible quality loss"
      }
    ],
    "contextMenu": [
      {
        "id": "convert",
        "title": "Convert",
        "icon": "RefreshCw",
        "group": "extensions",
        "order": 1,
        "when": {
          "entryType": "file",
          "fileExtensions": [
            "mp4",
            "mkv",
            "webm",
            "avi",
            "mov",
            "wmv",
            "flv",
            "ts",
            "mts",
            "m4v",
            "3gp",
            "png",
            "jpg",
            "jpeg",
            "webp",
            "bmp",
            "tiff",
            "tif",
            "avif",
            "gif"
          ]
        }
      },
      {
        "id": "reduceSize",
        "title": "Reduce size",
        "icon": "Minimize2",
        "group": "extensions",
        "order": 2,
        "when": {
          "entryType": "file",
          "fileExtensions": [
            "mp4",
            "mkv",
            "webm",
            "avi",
            "mov",
            "wmv",
            "flv",
            "ts",
            "mts",
            "m4v",
            "3gp",
            "png",
            "jpg",
            "jpeg",
            "webp",
            "bmp",
            "tiff",
            "tif",
            "avif",
            "gif"
          ]
        }
      }
    ]
  },
  "engines": {
    "sigmaFileManager": ">=2.0.0"
  },
  "devDependencies": {
    "@sigma-file-manager/api": "^1.2.0"
  }
}