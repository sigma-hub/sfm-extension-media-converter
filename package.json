{
  "$schema": "./node_modules/@sigma-file-manager/api/manifest.schema.json",
  "id": "sigma.media-converter",
  "name": "Media Converter",
  "version": "1.0.0",
  "publisher": {
    "name": "sigma-hub",
    "url": "https://github.com/sigma-hub"
  },
  "repository": "https://github.com/sigma-hub/sfm-extension-media-converter",
  "license": "MIT",
  "categories": [
    "Media"
  ],
  "extensionType": "api",
  "type": "module",
  "main": "dist/index.js",
  "icon": "icon.png",
  "media": [
    {
      "title": "Preview",
      "src": "preview-1.jpg",
      "type": "image"
    },
    {
      "title": "GIF",
      "src": "preview-2.jpg",
      "type": "image"
    },
    {
      "title": "Commands",
      "src": "preview-3.jpg",
      "type": "image"
    }
  ],
  "permissions": [
    "contextMenu",
    "commands",
    "notifications",
    "fs.read",
    "fs.write",
    "shell"
  ],
  "activationEvents": [
    "onInstall",
    "onUninstall",
    "onStartup",
    "onUpdate",
    "onEnable",
    "onDisable",
    "onCommand:sigma.media-converter.convert",
    "onCommand:sigma.media-converter.reduceSize"
  ],
  "contributes": {
    "commands": [
      {
        "id": "convert",
        "title": "Convert Media",
        "description": "Convert videos and images to other formats using FFmpeg"
      },
      {
        "id": "reduceSize",
        "title": "Reduce Media Size",
        "description": "Re-encode media to shrink files with minimal visible quality loss",
        "icon": "ImageDown"
      }
    ],
    "contextMenu": [
      {
        "id": "convert",
        "title": "Convert",
        "icon": "RefreshCw",
        "group": "extensions",
        "order": 1,
        "when": {
          "entryType": "file",
          "fileExtensions": [
            "mp4",
            "mkv",
            "webm",
            "avi",
            "mov",
            "wmv",
            "flv",
            "ts",
            "mts",
            "m4v",
            "3gp",
            "png",
            "jpg",
            "jpeg",
            "webp",
            "bmp",
            "tiff",
            "tif",
            "avif",
            "gif"
          ]
        }
      },
      {
        "id": "reduceSize",
        "title": "Reduce size",
        "icon": "ImageDown",
        "group": "extensions",
        "order": 2,
        "when": {
          "entryType": "file",
          "fileExtensions": [
            "mp4",
            "mkv",
            "webm",
            "avi",
            "mov",
            "wmv",
            "flv",
            "ts",
            "mts",
            "m4v",
            "3gp",
            "png",
            "jpg",
            "jpeg",
            "webp",
            "bmp",
            "tiff",
            "tif",
            "avif",
            "gif"
          ]
        }
      }
    ]
  },
  "engines": {
    "sigmaFileManager": ">=2.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@sigma-file-manager/api": "^1.5.0",
    "typescript": "~5.8.0"
  },
  "platforms": [
    "windows",
    "macos",
    "linux"
  ],
  "binaries": [
    {
      "id": "ffmpeg",
      "name": "FFmpeg",
      "version": "8.1",
      "repository": "https://ffmpeg.org",
      "assets": [
        {
          "platform": "windows",
          "arch": [
            "x64"
          ],
          "downloadUrl": "https://github.com/BtbN/FFmpeg-Builds/releases/download/autobuild-2026-04-06-13-14/ffmpeg-n8.1-7-ga3475e2554-win64-gpl-8.1.zip",
          "integrity": "sha256:573edb512a81540f93b7936d2605fff1e36a6a4a28e3255958f89bec7871029d",
          "archive": true,
          "executable": "bin/ffmpeg.exe"
        },
        {
          "platform": "windows",
          "arch": [
            "arm64"
          ],
          "downloadUrl": "https://github.com/BtbN/FFmpeg-Builds/releases/download/autobuild-2026-04-06-13-14/ffmpeg-n8.1-7-ga3475e2554-winarm64-gpl-8.1.zip",
          "integrity": "sha256:f4993eadd5a43ab0281465cfc43f722253b13ff7b78289f5031ef884c0cea166",
          "archive": true,
          "executable": "bin/ffmpeg.exe"
        },
        {
          "platform": "linux",
          "arch": [
            "x64"
          ],
          "downloadUrl": "https://github.com/BtbN/FFmpeg-Builds/releases/download/autobuild-2026-04-06-13-14/ffmpeg-n8.1-7-ga3475e2554-linux64-gpl-8.1.tar.xz",
          "integrity": "sha256:0a414da60b8e78ad58d461bc85ed181468614d349d16d497041ec076c817a4e1",
          "archive": true,
          "executable": "bin/ffmpeg"
        },
        {
          "platform": "linux",
          "arch": [
            "arm64"
          ],
          "downloadUrl": "https://github.com/BtbN/FFmpeg-Builds/releases/download/autobuild-2026-04-06-13-14/ffmpeg-n8.1-7-ga3475e2554-linuxarm64-gpl-8.1.tar.xz",
          "integrity": "sha256:a796d97e24fd88763e48d119b91262df220537f18e43bf4cc018e05f5b6bf94f",
          "archive": true,
          "executable": "bin/ffmpeg"
        },
        {
          "platform": "macos",
          "arch": [
            "x64"
          ],
          "downloadUrl": "https://evermeet.cx/ffmpeg/ffmpeg-8.1.zip",
          "integrity": "sha256:e9154d2ca2577a781c23387beed1af7a89b77201e19acf9f70de1af57cb526d4",
          "archive": true,
          "executable": "ffmpeg"
        },
        {
          "platform": "macos",
          "arch": [
            "arm64"
          ],
          "downloadUrl": "https://evermeet.cx/ffmpeg/ffmpeg-8.1.zip",
          "integrity": "sha256:e9154d2ca2577a781c23387beed1af7a89b77201e19acf9f70de1af57cb526d4",
          "archive": true,
          "executable": "ffmpeg"
        }
      ]
    }
  ]
}